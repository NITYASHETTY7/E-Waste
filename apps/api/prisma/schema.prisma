generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  passwordHash  String
  name          String
  phone         String?
  role          UserRole      @default(USER)
  companyId     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  emailVerified Boolean       @default(false)
  isActive      Boolean       @default(false)
  otpAttempts   Int           @default(0)
  otpCode       String?
  otpExpiresAt  DateTime?
  otpType       String?
  phoneVerified Boolean       @default(false)
  auditReports      AuditReport[]
  bids              Bid[]
  auditDocs         VendorAuditDoc[]      @relation("VendorAuditDocs")
  inAppNotifications InAppNotification[]
  company           Company?              @relation(fields: [companyId], references: [id])

  @@index([email])
}

model Company {
  id                 String            @id @default(cuid())
  name               String
  type               CompanyType
  status             CompanyStatus     @default(PENDING)
  gstNumber          String?
  panNumber          String?
  address            String?
  city               String?
  state              String?
  pincode            String?
  rating             Float?            @default(0)
  ratingCount        Int               @default(0)
  bankAccountHolder  String?
  bankName           String?
  bankAccountNumber  String?
  bankIfscCode       String?
  bankAccountType    String?
  isLocked           Boolean           @default(false)
  lockReason         String?
  penaltyAmount      Float?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  auctions         Auction[]         @relation("ClientAuctions")
  wonAuctions      Auction[]         @relation("WinnerAuctions")
  auditInvitations AuditInvitation[] @relation("VendorAuditInvitations")
  kycDocuments     KycDocument[]
  requirements     Requirement[]     @relation("ClientRequirements")
  users            User[]
}

model KycDocument {
  id         String       @id @default(cuid())
  type       DocumentType
  s3Key      String       @unique
  s3Bucket   String
  fileName   String
  mimeType   String?
  companyId  String
  uploadedAt DateTime     @default(now())
  company    Company      @relation(fields: [companyId], references: [id])
}

model Requirement {
  id                String            @id @default(cuid())
  title             String
  description       String?
  status            RequirementStatus @default(UPLOADED)
  rawS3Key          String?
  processedS3Key    String?
  targetPrice       Float?
  totalWeight       Float?
  category          String?
  clientId          String
  // Vendor IDs (User.id) invited by admin for sealed bidding
  invitedVendorIds  String[]          @default([])
  // Vendor responses to sealed bid invitation
  acceptedVendorIds       String[]          @default([])
  declinedVendorIds       String[]          @default([])
  auditApprovedVendorIds  String[]          @default([])
  // Sealed bid window set by client at listing creation
  sealedPhaseStart        DateTime?
  sealedPhaseEnd          DateTime?
  // Sealed bid event (created by admin after audits are reviewed)
  sealedBidEventCreatedAt DateTime?
  sealedBidDeadline       DateTime?
  // Admin approval tracking
  adminApprovedAt         DateTime?
  adminApprovedById       String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  auction                 Auction?
  auditInvitations        AuditInvitation[]
  auditDocs               VendorAuditDoc[]
  client                  Company           @relation("ClientRequirements", fields: [clientId], references: [id])
}

model AuditInvitation {
  id            String       @id @default(cuid())
  status        AuditStatus  @default(INVITED)
  requirementId String
  vendorId      String
  siteAddress   String?
  spocName      String?
  spocPhone     String?
  scheduledAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  requirement   Requirement  @relation(fields: [requirementId], references: [id])
  vendor        Company      @relation("VendorAuditInvitations", fields: [vendorId], references: [id])
  report        AuditReport?

  @@unique([requirementId, vendorId])
}

model AuditReport {
  id           String          @id @default(cuid())
  invitationId String          @unique
  productMatch Boolean?
  remarks      String?
  completedAt  DateTime?
  vendorUserId String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  photos       AuditPhoto[]
  invitation   AuditInvitation @relation(fields: [invitationId], references: [id])
  vendorUser   User?           @relation(fields: [vendorUserId], references: [id], onDelete: SetNull)
}

model AuditPhoto {
  id            String      @id @default(cuid())
  s3Key         String
  s3Bucket      String
  fileName      String
  mimeType      String?
  latitude      Float?
  longitude     Float?
  capturedAt    DateTime?
  auditReportId String
  uploadedAt    DateTime    @default(now())
  auditReport   AuditReport @relation(fields: [auditReportId], references: [id])
}

model Auction {
  id               String            @id @default(cuid())
  title            String
  category         String
  description      String?
  status           AuctionStatus     @default(DRAFT)
  basePrice        Float
  targetPrice      Float?
  tickSize         Float             @default(1000)
  maxTicks         Int               @default(24)
  extensionMinutes Int               @default(3)
  sealedPhaseStart DateTime?
  sealedPhaseEnd   DateTime?
  openPhaseStart   DateTime?
  openPhaseEnd     DateTime?
  extensionCount        Int               @default(0)
  liveApprovalStatus    String            @default("pending")
  liveApprovalRemarks   String?
  clientId              String
  winnerId              String?
  requirementId         String?           @unique
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  client           Company           @relation("ClientAuctions", fields: [clientId], references: [id])
  requirement      Requirement?      @relation(fields: [requirementId], references: [id])
  winner           Company?          @relation("WinnerAuctions", fields: [winnerId], references: [id])
  auctionDocs      AuctionDocument[]
  bids             Bid[]
  pickup           Pickup?
  quoteApproved    Boolean?
  quoteRemarks     String?
  payment          Payment?
}

model AuctionDocument {
  id         String       @id @default(cuid())
  type       DocumentType
  s3Key      String
  s3Bucket   String
  fileName   String
  mimeType   String?
  auctionId  String
  uploadedAt DateTime     @default(now())
  auction    Auction      @relation(fields: [auctionId], references: [id])
}

model VendorAuditDoc {
  id                  String      @id @default(cuid())
  requirementId       String
  vendorUserId        String
  auditReportS3Key    String?
  auditReportFileName String?
  excelS3Key          String?
  excelFileName       String?
  imageS3Keys         String[]    @default([])
  imageFileNames      String[]    @default([])
  status              String      @default("pending")
  adminRemarks        String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  requirement         Requirement @relation(fields: [requirementId], references: [id])
  vendor              User        @relation("VendorAuditDocs", fields: [vendorUserId], references: [id])

  @@unique([requirementId, vendorUserId])
}

model InAppNotification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bid {
  id                   String   @id @default(cuid())
  amount               Float
  phase                BidPhase
  remarks              String?
  rank                 Int?
  isShortlisted        Boolean  @default(false)
  auctionId            String
  vendorId             String
  priceSheetS3Key      String?
  priceSheetS3Bucket   String?
  priceSheetFileName   String?
  clientStatus         String   @default("pending")
  clientRemarks        String?
  createdAt            DateTime @default(now())
  auction              Auction  @relation(fields: [auctionId], references: [id])
  vendor               User     @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([auctionId, amount])
}
model Payment {
  id               String        @id @default(cuid())
  status           PaymentStatus @default(PENDING)
  clientAmount     Float
  commissionAmount Float
  totalAmount      Float
  utrNumber        String?
  paymentProofUrl  String?
  auction          Auction       @relation(fields: [auctionId], references: [id])
  proofS3Key       String?
  proofS3Bucket    String?
  auctionId        String        @unique
  adminNotes       String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  pickup           Pickup?
}

model Pickup {
  id            String           @id @default(cuid())
  status        PickupStatus     @default(PENDING)
  scheduledDate DateTime?
  auctionId     String           @unique
  paymentId     String?          @unique
  adminNotes    String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  auction       Auction          @relation(fields: [auctionId], references: [id])
  payment       Payment?         @relation(fields: [paymentId], references: [id])
  pickupDocs    PickupDocument[]
}

model PickupDocument {
  id         String       @id @default(cuid())
  type       DocumentType
  s3Key      String
  s3Bucket   String
  fileName   String
  mimeType   String?
  pickupId   String
  uploadedAt DateTime     @default(now())
  pickup     Pickup       @relation(fields: [pickupId], references: [id])
}

enum UserRole {
  ADMIN
  CLIENT
  VENDOR
  USER
}

enum CompanyStatus {
  PENDING
  APPROVED
  REJECTED
  BLOCKED
}

enum CompanyType {
  CLIENT
  VENDOR
}

enum RequirementStatus {
  UPLOADED
  PROCESSING
  CLIENT_REVIEW
  FINALIZED
  REJECTED
}

enum AuditStatus {
  INVITED
  ACCEPTED
  REJECTED
  SCHEDULED
  COMPLETED
}

enum AuctionStatus {
  DRAFT
  UPCOMING
  SEALED_PHASE
  OPEN_PHASE
  PENDING_SELECTION
  COMPLETED
  CANCELLED
}

enum BidPhase {
  SEALED
  OPEN
}

enum PaymentStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  FAILED
}

enum PickupStatus {
  PENDING
  SCHEDULED
  DOCUMENTS_UPLOADED
  COMPLETED
}

enum DocumentType {
  GST_CERTIFICATE
  PAN_CARD
  PCB_AUTHORIZATION
  EPR_AUTHORIZATION
  POLLUTION_CERTIFICATE
  TRADE_LICENSE
  PRICE_SHEET
  FINAL_QUOTE
  LETTERHEAD_QUOTATION
  PAYMENT_PROOF
  FORM_6
  WEIGHT_SLIP_EMPTY
  WEIGHT_SLIP_LOADED
  RECYCLING_CERTIFICATE
  DISPOSAL_CERTIFICATE
  AUDIT_GEO_PHOTO
  CERTIFICATE_OF_INCORPORATION
  COMPANY_PAN
  DIRECTOR_PAN
  AUTHORIZED_SIGNATORY_ID
  BOARD_RESOLUTION
  KYC_FORM
  EMD_PROOF
  TERMS_ACCEPTANCE
  RECYCLER_LICENSE
  FACTORY_LICENSE
  BUSINESS_INSURANCE
  VENDOR_ONBOARDING_FORM
  AUTHORIZATION_LETTER
  ADDRESS_PROOF
  E_WASTE_DECLARATION
  AADHAR_CARD
  CANCELLED_CHEQUE
  OTHER
  WORK_ORDER
}
